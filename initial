<script>
    // Language Toggle
    let lang = 'en';
    const toggleBtn = document.getElementById('langToggle');

    function setLanguage(language) {
        const enElements = document.querySelectorAll('.en-text');
        const esElements = document.querySelectorAll('.es-text');
        const enPlaceholders = document.querySelectorAll('.en-placeholder');
        const esPlaceholders = document.querySelectorAll('.es-placeholder');
        
        if (language === 'en') {
            enElements.forEach(el => el.classList.remove('hidden'));
            esElements.forEach(el => el.classList.add('hidden'));
            enPlaceholders.forEach(el => el.classList.remove('hidden'));
            esPlaceholders.forEach(el => el.classList.add('hidden'));
            toggleBtn.innerHTML = '🇪🇸 Español';
            lang = 'en';
        } else {
            enElements.forEach(el => el.classList.add('hidden'));
            esElements.forEach(el => el.classList.remove('hidden'));
            enPlaceholders.forEach(el => el.classList.add('hidden'));
            esPlaceholders.forEach(el => el.classList.remove('hidden'));
            toggleBtn.innerHTML = '🇺🇸 English';
            lang = 'es';
        }
        
        // Refresh testimonials display after language change
        displayTestimonials();
    }

    toggleBtn.addEventListener('click', () => {
        if (lang === 'en') {
            setLanguage('es');
        } else {
            setLanguage('en');
        }
    });

    // Testimonials Storage and Display
    let testimonials = [];

    // Load testimonials from localStorage
    function loadTestimonials() {
        const stored = localStorage.getItem('nff_testimonials');
        if (stored) {
            testimonials = JSON.parse(stored);
        }
        displayTestimonials();
    }

    // Save testimonials to localStorage
    function saveTestimonials() {
        localStorage.setItem('nff_testimonials', JSON.stringify(testimonials));
    }

    // Display testimonials on the page
    function displayTestimonials() {
        const container = document.getElementById('testimonials-list');
        const emptyEn = document.getElementById('empty-testimonials');
        const emptyEs = document.getElementById('empty-testimonials-es');
        
        if (!container) return;
        
        if (testimonials.length === 0) {
            container.innerHTML = '';
            if (emptyEn) emptyEn.classList.remove('hidden');
            if (emptyEs) emptyEs.classList.remove('hidden');
            return;
        }
        
        if (emptyEn) emptyEn.classList.add('hidden');
        if (emptyEs) emptyEs.classList.add('hidden');
        
        // Sort by date (newest first)
        const sorted = [...testimonials].reverse();
        
        container.innerHTML = sorted.map(t => {
            const date = new Date(t.date);
            const formattedDate = date.toLocaleDateString();
            return `
                <div class="testimonial-card">
                    <div class="testimonial-text">"${escapeHtml(t.story)}"</div>
                    <div class="testimonial-author">— ${escapeHtml(t.name)}</div>
                    <div class="testimonial-date">${formattedDate}</div>
                </div>
            `;
        }).join('');
    }

    // Simple escape function to prevent XSS
    function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        }).replace(/[\uD800-\uDBFF][\uDC00-\uDFFF]/g, function(c) {
            return c;
        });
    }

    // Submit new testimonial
    function submitTestimonial() {
        let name, story;
        
        if (lang === 'en') {
            name = document.getElementById('testimonial-name').value.trim();
            story = document.getElementById('testimonial-story').value.trim();
        } else {
            name = document.getElementById('testimonial-name-es').value.trim();
            story = document.getElementById('testimonial-story-es').value.trim();
        }
        
        const successDiv = document.getElementById('success-message');
        const errorDiv = document.getElementById('error-message');
        
        // Hide any previous messages
        successDiv.style.display = 'none';
        errorDiv.style.display = 'none';
        
        if (!name) {
            if (lang === 'en') {
                errorDiv.innerHTML = 'Please enter your name (or "Anonymous").';
            } else {
                errorDiv.innerHTML = 'Por favor ingrese su nombre (o "Anónimo").';
            }
            errorDiv.style.display = 'block';
            return;
        }
        
        if (!story) {
            if (lang === 'en') {
                errorDiv.innerHTML = 'Please share your story.';
            } else {
                errorDiv.innerHTML = 'Por favor comparta su historia.';
            }
            errorDiv.style.display = 'block';
            return;
        }
        
        if (story.length < 10) {
            if (lang === 'en') {
                errorDiv.innerHTML = 'Please share a bit more detail (at least 10 characters).';
            } else {
                errorDiv.innerHTML = 'Por favor comparta un poco más de detalle (al menos 10 caracteres).';
            }
            errorDiv.style.display = 'block';
            return;
        }
        
        const newTestimonial = {
            name: name.substring(0, 50),
            story: story.substring(0, 1000),
            date: new Date().toISOString()
        };
        
        testimonials.push(newTestimonial);
        saveTestimonials();
        displayTestimonials();
        
        // Clear form
        if (lang === 'en') {
            document.getElementById('testimonial-name').value = '';
            document.getElementById('testimonial-story').value = '';
            successDiv.innerHTML = 'Thank you for sharing your story! It has been added to the testimonials.';
        } else {
            document.getElementById('testimonial-name-es').value = '';
            document.getElementById('testimonial-story-es').value = '';
            successDiv.innerHTML = '¡Gracias por compartir su historia! Ha sido añadida a los testimonios.';
        }
        successDiv.style.display = 'block';
        
        // Track testimonial submission in Google Analytics
        if (typeof gtag !== 'undefined') {
            gtag('event', 'testimonial_submitted', {
                'event_category': 'engagement',
                'event_label': 'father_testimonial'
            });
        }
        
        // Scroll to testimonials section
        document.getElementById('testimonials').scrollIntoView({ behavior: 'smooth' });
    }
    
    // Initialize on page load
    document.addEventListener('DOMContentLoaded', () => {
        loadTestimonials();
        
        const submitBtn = document.getElementById('submit-testimonial');
        if (submitBtn) {
            submitBtn.addEventListener('click', submitTestimonial);
        }
        
        // Track page view in Google Analytics (already handled by gtag)
        if (typeof gtag !== 'undefined') {
            gtag('event', 'page_view', {
                'page_title': 'No Father Forgotten',
                'page_location': window.location.href
            });
        }
    });
</script>

